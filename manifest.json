{
  "manifest_version": 3,
  "name": "RedGifs Downloader",
  "version": "1.5.0",
  "description": "Ajoute des boutons de téléchargement HD/SD dans la barre latérale de chaque vidéo RedGifs (watch, feed, niches, profils).",

  "browser_specific_settings": {
    "gecko": {
      "id": "redgifs-dl@dayga.com",
      "strict_min_version": "115.0",
      "update_url": "https://daygaa.github.io/Redgifs-Downloader/updates.json"
    }
  },

  "permissions": [
    "downloads",
    "storage"
  ],

  "host_permissions": [
    "https://api.redgifs.com/*",
    "https://*.redgifs.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["*://www.redgifs.com/*", "*://redgifs.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "RedGifs Downloader",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "commands": {
    "download-hd": {
      "suggested_key": {
        "default": "Ctrl+Q"
      },
      "description": "Télécharger la vidéo RedGifs en HD"
    },
    "download-sd": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q"
      },
      "description": "Télécharger la vidéo RedGifs en SD"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  }
}
